NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxx

# VAPID keys cho Web Push — sinh bằng `npx web-push generate-vapid-keys`
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Secret dùng để xác thực request từ Supabase Database Webhook gọi vào
# /api/webhooks/sos
SUPABASE_WEBHOOK_SECRET=
